# ─── Required ────────────────────────────────────────────────────────────────

# MySQL / TiDB / PlanetScale connection string
DATABASE_URL=mysql://user:password@host:3306/dbname

# Secret used to sign session cookies (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-32-byte-hex-string

# Admin token for the /admin panel (set a strong random value)
ADMIN_TOKEN=change-me-to-a-strong-random-token

# ─── Optional ─────────────────────────────────────────────────────────────────

# Node environment (set to "production" on Zeabur)
NODE_ENV=production

# Port (Zeabur injects this automatically - do not set manually)
# PORT=3000
